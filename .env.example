# Core runtime
NODE_ENV=development
PORT=4173
APP_URL=http://localhost:4173
TRUST_PROXY=false
DATABASE_URL=postgresql://command:command@localhost:5432/command_ai
DATABASE_SSL=false
AUTO_MIGRATE=true
AUTO_SEED=true
LOG_LEVEL=info

# Generate each secret independently with: openssl rand -base64 48
SESSION_PEPPER=replace-with-at-least-32-random-characters
INTEGRATION_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
SESSION_COOKIE_NAME=command_session
SESSION_DAYS=7
COOKIE_SECURE=false

# Initial administrator. Remove ADMIN_PASSWORD from the host after first successful seed.
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=replace-with-a-unique-password-at-least-12-characters
ADMIN_NAME=Agency Owner
DEFAULT_TENANT_NAME=COMMAND AI
DEFAULT_TENANT_SLUG=command-ai

# OpenAI — required for live grounded responses
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_STORE=false
OPENAI_REASONING_EFFORT=low
# Set current provider prices for accurate margin reporting.
OPENAI_INPUT_COST_PER_MILLION=0
OPENAI_OUTPUT_COST_PER_MILLION=0

# Twilio — required for live inbound voice and SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VALIDATE_WEBHOOKS=false

# Stripe — required to collect recurring subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_RECEPTIONIST=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_OPERATOR=
STRIPE_PRICE_MULTI_LOCATION=

# HighLevel — global fallback. Per-tenant credentials can be encrypted in the dashboard.
HIGHLEVEL_BASE_URL=https://services.leadconnectorhq.com
HIGHLEVEL_ACCESS_TOKEN=
HIGHLEVEL_LOCATION_ID=
HIGHLEVEL_CALENDAR_ID=
HIGHLEVEL_API_VERSION=2021-07-28
HIGHLEVEL_WEBHOOK_SECRET=

# Limits
JSON_LIMIT=2mb
UPLOAD_MAX_BYTES=8388608
KNOWLEDGE_MAX_CHARS=500000
AGENT_MESSAGE_MAX_CHARS=4000
AGENT_RATE_LIMIT_PER_MINUTE=30
DATABASE_POOL_MAX=12
