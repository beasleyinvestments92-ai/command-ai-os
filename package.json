{
  "name": "command-ai-os",
  "version": "1.0.0-rc.1",
  "private": true,
  "description": "Production-ready white-label AI receptionist and business operating system",
  "type": "module",
  "scripts": {
    "materialize": "node scripts/materialize-source.cjs",
    "start": "node --env-file-if-exists=.env src/server.js",
    "dev": "node --watch --env-file-if-exists=.env src/server.js",
    "migrate": "node --env-file-if-exists=.env scripts/migrate.js",
    "seed": "node --env-file-if-exists=.env scripts/seed.js",
    "bootstrap": "npm run migrate && npm run seed",
    "test": "node --test --test-reporter=spec tests/*.test.js",
    "test:live-ai": "node --env-file-if-exists=.env scripts/live-ai-eval.js",
    "check": "node scripts/check.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "luxon": "^3.7.2",
    "multer": "^2.0.2",
    "openai": "^5.20.2",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "pino": "^9.9.4",
    "pino-http": "^10.5.0",
    "stripe": "^18.5.0",
    "twilio": "^5.10.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "pg-mem": "^3.0.5",
    "supertest": "^7.1.4"
  }
}
